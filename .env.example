# EmbedIQ Cloud — environment template.
# Real values are GENERATED by ./install.sh (secrets via `openssl rand`); the resulting
# `.env` is git-ignored and must never be committed. This file documents every variable.

# --- Admin (Admin UI / API login) ---
ADMIN_USER=admin
ADMIN_PASS_HASH=bcrypt-hash-generated-by-install.sh

# --- InfluxDB (telemetry) ---
INFLUX_USER=embediq
INFLUX_PASSWORD=generated-by-install.sh
INFLUX_ORG=embediq
INFLUX_BUCKET=telemetry
INFLUX_TOKEN=generated-by-install.sh

# --- Grafana (dashboards) ---
GRAFANA_ADMIN_PASS=generated-by-install.sh

# --- Hawkbit (OTA) ---
# HAWKBIT_URL/HAWKBIT_USER are internal defaults (not secrets); override only if needed.
HAWKBIT_URL=http://hawkbit:8080
HAWKBIT_USER=admin
HAWKBIT_ADMIN_PASS=generated-by-install.sh

# --- Internal service auth (Mosquitto auth plugin -> embediq-api, PR-B) ---
INTERNAL_API_KEY=generated-by-install.sh

# --- JWT signing secret (admin login tokens) ---
JWT_SECRET=generated-by-install.sh

# --- Service URLs ---
EMBEDIQ_API_URL=http://embediq-api:8080

# --- MQTT bridge (optional; internal defaults shown, not secrets) ---
# Set BRIDGE_ENABLED=false to disable the consumer (e.g. in CI/tests).
BRIDGE_ENABLED=true
